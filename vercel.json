{
  "framework": "nextjs",
  "buildCommand": "npm run build",
  "functions": {
    "src/app/api/**/*.ts": {
      "maxDuration": 120
    }
  },
  "crons": [
    {
      "path": "/api/cron/contest-weekly",
      "schedule": "59 23 * * 0"
    },
    {
      "path": "/api/cron/milestones-unlock",
      "schedule": "15 3 * * *"
    },
    {
      "path": "/api/cron/trust-recompute",
      "schedule": "45 3 * * *"
    }
  ]
}
